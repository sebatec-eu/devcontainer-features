{
  "id": "setup-mistral-vibe",
  "version": "1.1.0",
  "name": "Setup Mistral Vibe",
  "description": "Installs mistral-vibe and mounts the user's .vibe configuration directory.",
  "options": {},
  "installsAfter": ["ghcr.io/devcontainers/features/common-utils"],
  "mounts": [
    {
      "type": "bind",
      "source": "${localEnv:HOME}/.vibe",
      "target": "/tmp/.vibe-mount"
    }
  ],
  "containerEnv": {
    "VIBE_HOME": "/tmp/.vibe-mount"
  }
}
